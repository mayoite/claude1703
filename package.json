    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "postgres": "^3.4.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "puppeteer": "^24.37.5",
